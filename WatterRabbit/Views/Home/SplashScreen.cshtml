
@{
    // Disable the shared layout so this page renders standalone.
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <!--added-->
    <meta charset="utf-8" />

    <meta name="viewport" content="width=device-width" , initial-scale="1.0" />
    <title>SplashScreen</title>

    <link href="https://fonts.googleapis.com/css?family=Montserrat" rel="stylesheet">

    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")

    <style>
        body {
            font: 20px Montserrat, sans-serif;
            line-height: 1.8;
            color: #2f2f2f; /* Black Gray */
            padding-top: 0px;
            padding-bottom: 0px;
        }

        .bg-1 {
            background-color: #000000; /* Black */
            color: #fff;
        }

        .container-fluid {
            padding-top: 70px;
            padding-bottom: 70px;
        }

        .margin {
            margin-bottom: 45px;
        }
        /* unvisited link */
        a:link {
            color: white;
            text-decoration: none;
            font-size: 200%;
        }
        /* visited link */
        a:visited {
            color: white;
            text-decoration: none;
            font-size: 200%;
            
        }
        /* mouse over link */
        a:hover {
            color: lightblue;
            text-decoration: none;
            font-size: 200%;
        }
        /* selected link */
        a:active {
            color: white;
            text-decoration: none;
            font-size: 200%;
        }
    </style>
</head>
<body>
    <div class="container-fluid bg-1 text-center">
        @Html.ActionLink("Are you thirsty?", "Index", "Home", new { @class = "margin"})

        <video autoplay loop muted class="img-fluid" src="~/Images/WaterRabbitVideo.mp4" />  
    </div>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
</body>


</html>
